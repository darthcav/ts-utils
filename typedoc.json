{
    "$schema": "https://typedoc.org/schema.json",
    "entryPoints": ["./src/index.ts"],
    "out": "./public",
    "readme": "README.md",
    "externalSymbolLinkMappings": {
        "@logtape/logtape": {
            "Logger": "https://jsr.io/@logtape/logtape/doc/~/Logger",
            "LogLevel": "https://jsr.io/@logtape/logtape/doc/~/LogLevel"
        }
    },
    "highlightLanguages": [
        "bash",
        "console",
        "css",
        "html",
        "javascript",
        "json",
        "jsonc",
        "json5",
        "jsx",
        "tsx",
        "typescript"
    ]
}
