{
    "name": "@darthcav/ts-utils",
    "description": "A collection of utility functions for TypeScript applications and modules",
    "version": "0.1.0",
    "author": {
        "name": "darthcav"
    },
    "license": "Apache-2.0",
    "type": "module",
    "publishConfig": {
        "access": "public"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "package.json",
        "package-lock.json",
        "README.md",
        "LICENSE",
        "src/**/*.ts",
        "src/**/*.tsx",
        "dist/**/*.js",
        "dist/**/*.js.map",
        "dist/**/*.d.ts",
        "dist/**/*.d.ts.map"
    ],
    "dependencies": {
        "@logtape/logtape": "2.0.4"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.6",
        "@types/node": "25.3.5",
        "asserttt": "1.0.1",
        "shx": "0.4.0",
        "typedoc": "0.28.17"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/darthcav/ts-utils.git"
    },
    "engines": {
        "node": ">=25"
    },
    "scripts": {
        "\n===== Build =====": "",
        "build": "npm run clean && tsc",
        "prepare": "npm run build",
        "clean": "shx rm -rf dist/*",
        "\n===== Typecheck =====": "",
        "typecheck": "tsc --noEmit",
        "\n===== Test =====": "",
        "test": "node --env-file=.env.local --test --test-reporter=spec 'src/**/*.test.ts'",
        "test:coverage": "node --env-file=.env.local --experimental-test-coverage --test 'src/**/*.test.ts'",
        "\n===== Linter =====": "",
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "\n===== TypeDoc =====": "",
        "doc": "shx rm -rf public/* && typedoc --tsconfig tsconfig.json"
    }
}
